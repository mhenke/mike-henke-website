{# Disqus comments partial: Only include on blog posts, not on section landing pages or non-blog content #}
<section id="comments" class="comments-section">
  <h2>Comments</h2>
  <div id="disqus_thread"></div>
</section>

<script>
  var disqus_config = function () {
    this.page.url = "{{ page.url | absoluteUrl(site.url) }}";
    this.page.identifier = "{{ page.fileSlug }}";
  };
  (function() {
    var d = document, s = d.createElement('script');
    s.src = 'https://mikehenke.disqus.com/embed.js';
    s.setAttribute('data-timestamp', +new Date());
    (d.head || d.body).appendChild(s);
  })();
</script>
<noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript>